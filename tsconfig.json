{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@rally/domain": ["packages/domain/src/index.ts"],
      "@rally/simulation": ["packages/simulation/src/index.ts"],
      "@rally/data-gen": ["packages/data-gen/src/index.ts"],
      "@rally/importers": ["packages/importers/src/index.ts"]
    }
  },
  "include": ["packages/**/*.ts", "apps/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
